# Copy to .env and adjust. docker-compose reads these.
POSTGRES_USER=lwag
POSTGRES_PASSWORD=lwag_dev_password
POSTGRES_DB=lwag
POSTGRES_PORT=5432

# Server-only connection string for a future API adapter. Never expose this as
# a VITE_* variable or connect to Postgres directly from the browser.
# Local Docker:
#   DATABASE_URL=postgresql://lwag:lwag_dev_password@localhost:5432/lwag
# For Supabase / Railway, use the server-side connection string they provide.
DATABASE_URL=postgresql://lwag:lwag_dev_password@localhost:5432/lwag
